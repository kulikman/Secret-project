# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in real values.
# All variables are validated by Zod at startup (src/lib/env.ts).
# Production values live in `vercel env` — never commit .env.local.
# ===========================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App (required) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Тайное Бюро

# --- Brain (server-only, optional until Knowledge Engine is wired) ---
BRAIN_API_URL=https://brain.elaurion.com
# Anton provisions this token outside git/chat. Use a key scoped to the public archive project only.
BRAIN_API_KEY=
# Optional founder/admin key for destructive cross-project operations like
# deleting archived Brain projects from the admin console.
BRAIN_ADMIN_API_KEY=
# Optional delete endpoint template. Leave empty unless the deployed Brain/OS
# contract exposes project deletion. Use {projectRef} as slug placeholder.
BRAIN_PROJECT_DELETE_ENDPOINT_TEMPLATE=
# Prefer one project binding. Recommended slug: secret-bureau-public-archive
BRAIN_PROJECT_ID=
BRAIN_PROJECT_SLUG=

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# --- AI (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Server-only key for on-demand topic research via Perplexity Sonar.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# --- Email (optional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@example.com

# --- Cron jobs (set when wiring scheduled routes; min 16 chars) ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Rate limiting (optional — falls back to in-memory) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Error tracking (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Product analytics — PostHog (optional) ---
# Get your key at https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Feature flags (optional) ---
# Flip to "true" or "1" to enable each section without redeploy.
NEXT_PUBLIC_FF_AI=false
NEXT_PUBLIC_FF_ANALYTICS=false
NEXT_PUBLIC_FF_ONBOARDING=false
NEXT_PUBLIC_FF_NOTIFICATIONS=false
NEXT_PUBLIC_FF_API_KEYS=false
